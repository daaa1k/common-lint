{
  "extends": ["github>daaa1k/renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "actionlint: ARG version + amd64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+ACTIONLINT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "amd64\\)[\\s\\S]*?ACTIONLINT_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "rhysd/actionlint",
      "versioningTemplate": "semver",
      "depNameTemplate": "actionlint-linux-amd64-tarball"
    },
    {
      "customType": "regex",
      "description": "actionlint: ARG version + arm64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+ACTIONLINT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "arm64\\)[\\s\\S]*?ACTIONLINT_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "rhysd/actionlint",
      "versioningTemplate": "semver",
      "depNameTemplate": "actionlint-linux-arm64-tarball"
    },
    {
      "customType": "regex",
      "description": "ghalint: ARG version + amd64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+GHALINT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "amd64\\)[\\s\\S]*?GHALINT_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "suzuki-shunsuke/ghalint",
      "versioningTemplate": "semver",
      "depNameTemplate": "ghalint-linux-amd64-tarball"
    },
    {
      "customType": "regex",
      "description": "ghalint: ARG version + arm64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+GHALINT_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "arm64\\)[\\s\\S]*?GHALINT_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "suzuki-shunsuke/ghalint",
      "versioningTemplate": "semver",
      "depNameTemplate": "ghalint-linux-arm64-tarball"
    },
    {
      "customType": "regex",
      "description": "zizmor: ARG version + amd64 tarball SHA256 (keep in sync; see arm64 manager + packageRules group)",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+ZIZMOR_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "amd64\\)[\\s\\S]*?ZIZMOR_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "zizmorcore/zizmor",
      "versioningTemplate": "semver",
      "depNameTemplate": "zizmor-linux-amd64-tarball"
    },
    {
      "customType": "regex",
      "description": "zizmor: ARG version + arm64 tarball SHA256 (grouped with amd64 so one PR updates all three fields)",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+ZIZMOR_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "arm64\\)[\\s\\S]*?ZIZMOR_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "zizmorcore/zizmor",
      "versioningTemplate": "semver",
      "depNameTemplate": "zizmor-linux-arm64-tarball"
    },
    {
      "customType": "regex",
      "description": "trivy: ARG version + amd64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+TRIVY_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "amd64\\)[\\s\\S]*?TRIVY_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "aquasecurity/trivy",
      "versioningTemplate": "semver",
      "depNameTemplate": "trivy-linux-amd64-tarball"
    },
    {
      "customType": "regex",
      "description": "trivy: ARG version + arm64 tarball SHA256",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG\\s+TRIVY_VERSION=(?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        "arm64\\)[\\s\\S]*?TRIVY_SHA256=(?<currentDigest>[a-f0-9]{64})"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "aquasecurity/trivy",
      "versioningTemplate": "semver",
      "depNameTemplate": "trivy-linux-arm64-tarball"
    }
  ],
  "packageRules": [
    {
      "description": "Container action npm deps (Dockerfile COPY npm-deps/) - group commitlint packages",
      "matchFileNames": ["npm-deps/package.json"],
      "matchPackageNames": [
        "@commitlint/cli",
        "@commitlint/config-conventional"
      ],
      "groupName": "action commitlint"
    },
    {
      "description": "One Renovate PR for actionlint: ARG + amd64 SHA + arm64 SHA (avoid version-only bump breaking docker build)",
      "matchDepNames": [
        "actionlint-linux-amd64-tarball",
        "actionlint-linux-arm64-tarball"
      ],
      "groupName": "actionlint"
    },
    {
      "description": "One Renovate PR for ghalint: ARG + amd64 SHA + arm64 SHA",
      "matchDepNames": [
        "ghalint-linux-amd64-tarball",
        "ghalint-linux-arm64-tarball"
      ],
      "groupName": "ghalint"
    },
    {
      "description": "One Renovate PR for zizmor: ARG + amd64 SHA + arm64 SHA",
      "matchDepNames": [
        "zizmor-linux-amd64-tarball",
        "zizmor-linux-arm64-tarball"
      ],
      "groupName": "zizmor"
    },
    {
      "description": "One Renovate PR for trivy: ARG + amd64 SHA + arm64 SHA",
      "matchDepNames": [
        "trivy-linux-amd64-tarball",
        "trivy-linux-arm64-tarball"
      ],
      "groupName": "trivy"
    }
  ]
}
